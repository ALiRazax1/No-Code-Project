{
  "name": "@keybridge/security",
  "version": "1.0.0",
  "description": "Standalone security & storage module for KeyBridge. Handles AES-256-GCM encryption, per-user key derivation, cloud (Postgres) and local-only (IndexedDB) storage adapters.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "test": "jest --runInBand --forceExit",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage --runInBand --forceExit",
    "lint": "tsc --noEmit"
  },
  "keywords": [
    "encryption",
    "aes-256-gcm",
    "api-key-storage",
    "keybridge"
  ],
  "license": "MIT",
  "dependencies": {
    "idb": "^8.0.0",
    "pg": "^8.12.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.11.6",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.4"
  }
}
