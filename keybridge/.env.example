# KeyBridge — Environment Variables
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local to source control.

# ── Database ─────────────────────────────────────────────────────────────────
# Postgres connection string (Supabase, Neon, or self-hosted)
DATABASE_URL=postgresql://user:password@host:5432/keybridge

# ── Encryption (Track 1 & 5) ─────────────────────────────────────────────────
# Root secret used to derive per-user encryption keys via HKDF-SHA256.
# Must be at least 32 characters. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#
# WARNING: Rotating this value without re-encrypting all stored keys will
# make existing keys unrecoverable. Keep a secure backup.
MASTER_ENCRYPTION_SECRET=

# ── Injection API (Track 5) ───────────────────────────────────────────────────
# Shared secret for the internal /api/internal/retrieve-key endpoint.
# Only trusted server-side callers should know this value.
# Must be at least 32 characters. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#
# This is NOT the same as MASTER_ENCRYPTION_SECRET — they serve different
# purposes and should be different values.
INTERNAL_API_SECRET=

# ── Auth ─────────────────────────────────────────────────────────────────────
# (Reuse your existing auth module's env vars here)
# NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000
