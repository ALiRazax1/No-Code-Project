# Server
PORT=4000
CLIENT_ORIGIN=http://localhost:5173
NODE_ENV=development

# JWT + CSRF secrets — replace these with strong, random, DISTINCT values
# in production. e.g. `openssl rand -hex 64` for each one.
#
# In production (NODE_ENV=production), the server enforces this at startup
# and refuses to start if any of the three below are: missing, left as the
# placeholder text shown here, shorter than 32 characters, or identical to
# each other. See server/src/config.ts (requireSecret /
# assertSecretsAreDistinct) for the exact checks. None of this applies
# outside production — local dev and tests are unaffected.
ACCESS_TOKEN_SECRET=replace-with-a-long-random-access-secret
REFRESH_TOKEN_SECRET=replace-with-a-long-random-refresh-secret
CSRF_SECRET=replace-with-a-long-random-csrf-secret

# Token lifetimes
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=7d

# Cookie name used for the session
SESSION_COOKIE_NAME=__miniclerk_session

# Database
# "memory" (default — zero setup, resets on every restart) or "mongodb".
# See server/src/db/index.ts for how this selects an adapter.
DB_PROVIDER=memory

# Required only when DB_PROVIDER=mongodb.
# Local MongoDB:      mongodb://localhost:27017/miniclerk
# MongoDB Atlas:       mongodb+srv://<user>:<password>@<cluster>/miniclerk
MONGODB_URI=mongodb://localhost:27017/miniclerk

# Mailer
# "console" (default — logs "sent" emails to the terminal, never actually
# sends anything; local-dev only) or "resend". See server/src/mailer/index.ts
# for how this selects an implementation.
MAILER_PROVIDER=console

# Required only when MAILER_PROVIDER=resend. Get one at resend.com/api-keys.
RESEND_API_KEY=

# The address (and optional display name) your emails are sent from.
# `onboarding@resend.dev` works out of the box for testing but Resend
# restricts who it can actually deliver to — once you're sending to real
# users, verify your own domain in the Resend dashboard and put an address
# on that domain here instead, e.g. "MiniClerk <noreply@yourdomain.com>".
MAIL_FROM_ADDRESS=MiniClerk <onboarding@resend.dev>

# Logging
# pino level names: fatal, error, warn, info, debug, trace, silent.
# Defaults to "info" in development (every request visible while you work)
# and "warn" in production (per-request noise off by default — auth
# security events like failed sign-in, session reuse, and CSRF failures
# are always logged at "warn" or above regardless, so this default never
# silences them). Uncomment to override either environment.
# LOG_LEVEL=info

# The frontend's URL, used to build links inside verification/reset emails
# (e.g. APP_URL/verify-email?token=...). Usually the same as CLIENT_ORIGIN
# locally.
APP_URL=http://localhost:5173

# Optional token lifetime overrides (defaults shown below, in milliseconds).
# EMAIL_VERIFICATION_TOKEN_TTL_MS=86400000
# PASSWORD_RESET_TOKEN_TTL_MS=3600000

# Optional rate-limit overrides — defaults shown below, usually fine as-is.
# Uncomment to change. (The test suite sets its own values automatically;
# you don't need to touch these to run tests.)
# AUTH_RATE_LIMIT_WINDOW_MS=900000
# AUTH_RATE_LIMIT_MAX=100
# SIGNIN_RATE_LIMIT_WINDOW_MS=900000
# SIGNIN_RATE_LIMIT_MAX=10
# SIGNUP_RATE_LIMIT_WINDOW_MS=3600000
# SIGNUP_RATE_LIMIT_MAX=5
# FORGOT_PASSWORD_RATE_LIMIT_WINDOW_MS=3600000
# FORGOT_PASSWORD_RATE_LIMIT_MAX=5
# RESEND_VERIFICATION_RATE_LIMIT_WINDOW_MS=3600000
# RESEND_VERIFICATION_RATE_LIMIT_MAX=3
